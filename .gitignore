# Data (large / re-downloadable from Kaggle, not meant to be committed)
data/raw/*.csv
data/raw/*.zip

# DuckDB store (regenerable from data/raw via train_pipeline.py)
data/processed/*.duckdb

# Model artifacts and run metadata (regenerate via training; run-specific)
models/**

# Logs
reports/*.log

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Claude Code local state
.claude/
